Options -Indexes

# Serve a real, styled 404 (not the homepage) for unknown URLs.
# Resolves the soft-404: every route is prerendered to its own .html, so there
# is no need for an SPA fallback to /index.html (which returned HTTP 200 for
# broken links and made Google treat every bad URL as a valid page).
ErrorDocument 404 /404.html

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Let real files and directories (e.g. /about/ -> /about/index.html) resolve.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Anything else genuinely does not exist: return a proper 404 status, which
  # triggers the ErrorDocument above to render /404.html.
  RewriteRule ^ - [R=404,L]
</IfModule>

<IfModule mod_headers.c>
  # HSTS — tell browsers to use HTTPS for 1 year; include subdomains
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"

  # Prevent MIME sniffing
  Header always set X-Content-Type-Options "nosniff"

  # Limit referrer info to same origin for cross-origin requests
  Header always set Referrer-Policy "strict-origin-when-cross-origin"

  # Disable browser features not needed by this site
  Header always set Permissions-Policy "camera=(), microphone=(), geolocation=()"

  # Prevent clickjacking
  Header always set X-Frame-Options "SAMEORIGIN"
</IfModule>

# Redirect www to apex (301)
<IfModule mod_rewrite.c>
  RewriteCond %{HTTP_HOST} ^www\.eljonesdigital\.com [NC]
  RewriteRule ^ https://eljonesdigital.com%{REQUEST_URI} [L,R=301]
</IfModule>
